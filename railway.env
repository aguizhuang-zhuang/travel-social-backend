# Railway 会自动注入 DATABASE_URL
DB_HOST=${RAILWAY_STATIC_URL?}
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=${RAILWAY_STATIC_URL?}
DB_NAME=railway

# JWT 配置
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# 服务器配置
PORT=3000
NODE_ENV=production

# CORS 配置
CORS_ORIGIN=https://aguizhuang-zhuang.github.io

# 支付配置（暂不启用）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 地图 API（暂不启用）
GOOGLE_MAPS_API_KEY=