# ============================================================
# 泰国社交活动平台 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 命令：cp .env.example .env
# ============================================================

# --- 服务器端口 ---
PORT=3000

# --- PostgreSQL 数据库连接配置 ---
# 数据库主机地址（本地开发通常为 localhost）
DB_HOST=localhost
# 数据库端口（PostgreSQL 默认 5432）
DB_PORT=5432
# 数据库名称
DB_NAME=travel_social
# 数据库用户名
DB_USER=postgres
# 数据库密码
DB_PASSWORD=your_password_here

# --- JWT 认证配置 ---
# JWT 签名密钥（生产环境请使用足够长且随机的字符串）
JWT_SECRET=change_me_to_a_random_secret_string
# JWT Token 过期时间（示例：7d = 7天，24h = 24小时）
JWT_EXPIRES_IN=7d

# --- Airwallex（空中云汇）支付配置 ---
# Airwallex API Key（从 Airwallex 控制台获取）
AIRWALLEX_API_KEY=your_api_key_here
# Airwallex Client ID（从 Airwallex 控制台获取）
AIRWALLEX_CLIENT_ID=your_client_id_here
# Airwallex Webhook 签名密钥（用于验证 Webhook 回调真实性）
AIRWALLEX_WEBHOOK_SECRET=your_webhook_secret_here
# Airwallex 环境（demo = 测试环境，prod = 生产环境）
AIRWALLEX_ENV=demo
